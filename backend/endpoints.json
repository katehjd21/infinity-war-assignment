{
  
  "GET /v1/coins": {
    "description": "Retrieves a list of all coins with their id and name.",
    "exampleResponse": [
      {
        "id": "uuid-of-coin",
        "name": "Example Coin"
      }
    ]
  },

  "GET /v2/coins": {
    "description": "Retrieves a list of all coins along with the duties associated with each coin.",
    "exampleResponse": [
      {
        "id": "uuid-of-coin",
        "name": "Example Coin",
        "duties": [
          {
            "id": "uuid-of-duty",
            "code": "D1",
            "name": "Duty 1 Name",
            "description": "Duty 1 Description"
          }
        ]
      }
    ]
  },

  "GET /v3/coins": {
    "description": "Retrieves a list of all coins along with the duties associated with each coin and the coin completion state.",
    "authentication": "No authentication required",
    "exampleResponse": [
      {
        "id": "uuid-of-coin",
        "name": "Example Coin",
        "completed": true,
        "duties": [
          {
            "id": "uuid-of-duty",
            "code": "D1",
            "name": "Duty 1 Name",
            "description": "Duty 1 Description"
          }
        ]
      }
    ]
  },

  "GET /v1/coins/:coin_id": {
    "description": "Retrieves a single coin by its UUID with id and name.",
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Example Coin"
    }
  },

  "GET /v2/coins/:coin_id": {
    "description": "Retrieves a single coin by its UUID along with associated duties.",
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Example Coin",
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        }
      ]
    }
  },

  "GET /v3/coins/:coin_id": {
    "description": "Retrieves a single coin by its UUID along with associated duties and completion state.",
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Example Coin",
      "completed": true,
      "duties": [
        {
            "id": "uuid-of-duty",
            "code": "D1",
            "name": "Duty 1 Name",
            "description": "Duty 1 Description"
          }
      ]
    }
  },

  "POST /v1/coins": {
    "description": "Creates a new coin with a name only.",
    "requestBody": {
      "name": "Example Coin"
    },
    "exampleResponse": {
      "id": "uuid-of-new-coin",
      "name": "Example Coin"
    }
  },

  "POST /v2/coins": {
    "description": "Creates a new coin and optionally associates duties using duty_codes.",
    "requestBody": {
      "name": "Example Coin",
      "duty_codes": ["D1", "D2"]
    },
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Example Coin",
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        },
        {
          "id": "uuid-of-duty",
          "code": "D2",
          "name": "Duty 2 Name",
          "description": "Duty 2 Description"
        }
      ]
    }
  },

  "POST /v3/coins": {
    "description": "Admin only. Creates a coin with duties and completion support.",
    "authentication": "Admin required to create coin",
    "requestBody": {
      "name": "Example Coin",
      "completed": false,
      "duty_codes": ["D1", "D2"]
    },
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Example Coin",
      "completed": false,
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        },
        {
          "id": "uuid-of-duty",
          "code": "D2",
          "name": "Duty 2 Name",
          "description": "Duty 2 Description"
        }
      ]
    }
  },

  "POST /coins/:coin_id/complete": {
    "description": "Toggles completion status for a coin.",
    "authentication": "Must be authenticated or admin user",
    "requestBody": null,
    "exampleResponse": {
      "message": "Coin completion toggled",
      "coin_id": "123",
      "completed": true
    }
  },
  
  "PATCH /v1/coins/:coin_id": {
    "description": "Updates the name of a coin by UUID.",
    "requestBody": {
      "name": "Updated Coin Name"
    },
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Updated Coin Name"
    }
  },
  "PATCH /v2/coins/:coin_id": {
    "description": "Updates the name and/or associated duties of a coin.",
    "requestBody": {
      "name": "Updated Coin Name",
      "duty_codes": ["D1", "D3"]
    },
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Updated Coin Name",
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        },
        {
          "id": "uuid-of-duty",
          "code": "D3",
          "name": "Duty 3 Name",
          "description": "Duty 3 Description"
        }
      ]
    }
  },

  "PATCH /v3/coins/:coin_id": {
    "description": "Updates the name and/or associated duties and/or completion status of a coin.",
    "authentication": "Admin required to update coin",
    "requestBody": {
      "name": "Updated Coin Name",
      "duty_codes": ["D1", "D3"],
      "completed": true
    },
    "exampleResponse": {
      "id": "uuid-of-coin",
      "name": "Updated Coin Name",
      "completed": true,
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        },
        {
          "id": "uuid-of-duty",
          "code": "D3",
          "name": "Duty 3 Name",
          "description": "Duty 3 Description"
        }
      ]
    }
  },

  "DELETE /coins/:coin_id": {
    "description": "Deletes a coin by UUID. Returns a 200 OK with a success message on successful deletion.",
    "exampleResponse": {
      "message": "Coin has been successfully deleted!"
    }
  },

  "DELETE /v2/coins/:coin_id": {
    "description": "Deletes a coin by UUID. Returns a 200 OK with a success message on successful deletion.",
    "authentication": "Admin required to delete coin",
    "exampleResponse": {
      "message": "Coin has been successfully deleted!"
    }
  },

  "GET /v1/duties": {
    "description": "Retrieves a list of all duties.",
    "exampleResponse": [
      {
        "id": "uuid-of-duty",
        "code": "D1",
        "name": "Duty 1 Name",
        "description": "Duty 1 Description"
      }
    ]
  },

  "GET /v2/duties": {
    "description": "Retrieves a list of all duties with their associated coins and ksbs.",
    "exampleResponse": [
      {
        "id": "uuid-of-duty",
        "code": "D1",
        "name": "Duty 1 Name",
        "description": "Duty 1 Description",
        "coins": [
          {
            "id": "uuid-of-coin",
            "name": "Coin Name"
          }
        ],
        "ksbs": ["K1", "S1", "B1"]
      }
    ]
  },

  "GET /duties/:duty_code": {
    "description": "Retrieves a single duty by code along with coins and ksbs associated with it.",
    "exampleResponse": {
      "id": "uuid-of-duty",
      "code": "D1",
      "name": "Duty 1 Name",
      "description": "Duty 1 Description",
      "coins": [
        {
          "id": "uuid-of-coin",
          "name": "Example Coin"
        }
      ],
      "ksbs": ["K1", "S1", "B1"]
    }
  },

  "POST /v1/duties": {
    "description": "Creates a duty.",
    "requestBody": {
      "code": "D10",
      "name": "New Duty",
      "description": "Duty description",
      "coin_ids": ["uuid-of-coin"],
      "ksb_codes": ["K1", "S1", "B1"]
    }
  },

  "POST /v2/duties": {
    "description": "Admin only duty creation.",
    "authentication": "Admin required",
    "requestBody": {
      "code": "D10",
      "name": "New Duty",
      "description": "Duty description",
      "coin_ids": ["uuid-of-coin"],
      "ksb_codes": ["K1", "S1", "B1"]
    },
    "exampleResponse": {
    "code": "D10",
    "name": "New Duty",
    "description": "Duty description",
    "coins": [],
    "ksbs": []
    }  
  },

  "PATCH /v1/duties/:duty_code": {
    "description": "Updates a duty including coins and KSB associations.",

  },

  "PATCH /v2/duties/:duty_code": {
    "description": "Admin only duty update.",
    "authentication": "Admin required"

  },

  "DELETE /v1/duties/:duty_code": {
    "description": "Deletes a duty.",

  },

  "DELETE /v2/duties/:duty_code": {
    "description": "Admin only duty deletion.",
    "authentication": "Admin required"

  },

  "GET /ksbs": {
    "description": "Retrieves a list of all KSBs (Knowledge, Skill, Behaviour).",
    "exampleResponse": [
      {
        "id": "uuid-of-ksb",
        "code": "K1",
        "name": "Knowledge 1 Name",
        "description": "Knowledge 1 Description",
        "type": "Knowledge"
      },
      {
        "id": "uuid-of-ksb",
        "code": "S1",
        "name": "Skill 1 Name",
        "description": "Skill 1 Description",
        "type": "Skill"
      },
      {
        "id": "uuid-of-ksb",
        "code": "B1",
        "name": "Behaviour 1 Name",
        "description": "Behaviour 1 Description",
        "type": "Behaviour"
      }
    ]
  },

  "GET /ksbs/:ksb_code": {
    "description": "Retrieves a single KSB by code along with associated duties.",
    "exampleResponse": {
      "id": "uuid-of-ksb",
      "code": "K1",
      "name": "Knowledge 1 Name",
      "description": "Knowledge 1 Description",
      "type": "Knowledge",
      "duties": [
        {
          "id": "uuid-of-duty",
          "code": "D1",
          "name": "Duty 1 Name",
          "description": "Duty 1 Description"
        },
        {
          "id": "uuid-of-duty",
          "code": "D2",
          "name": "Duty 2 Name",
          "description": "Duty 2 Description"
        }
      ]
    }
  },

  "POST /login": {
    "description": "Logs in a user.",
    "requestBody": {
      "username": "admin",
      "password": "password"
    },
    "exampleResponse": {
      "message": "Login successful",
      "role": "admin"
    },
    "errors": [
      { "code": 401, "description": "Invalid credentials." },
      { "code": 400, "description": "Missing username or password." }
    ]
  },

  "POST /logout": {
    "description": "Logs out current user.",
    "exampleResponse": {
      "message": "Logged out"
    },
    "errors": [
      { "code": 401, "description": "User not logged in." }
    ]
  },

  "GET /admin/logs": {
    "description": "Returns the 100 most recent request logs.",
    "authentication": "Admin required",
    "errors": [
      { "code": 401, "description": "Authentication required." },
      { "code": 403, "description": "Admin privileges required." }
    ]
  }
}